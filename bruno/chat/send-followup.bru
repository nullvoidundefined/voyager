meta {
  name: Send Follow-up Message (SSE)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/trips/{{tripId}}/chat
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Accept: text/event-stream
}

body:json {
  {
    "message": "Can you find cheaper flights? I'm flexible on dates by a few days."
  }
}
